{
  "name": "optionsheet",
  "version": "1.0.0",
  "description": "A platform for logging and analyzing stock and option trades.",
  "main": "index.js",
  "scripts": {
    "build": "run-s webpack:server webpack:client",
    "start": "pm2 start ./build/server.js",
    "start:dev": "run-p webpack:server:dev serve:dev webpack:client:dev",
    "serve:dev": "nodemon ./build/server.js",
    "webpack:client": "webpack --config webpack.config.client.js --mode production",
    "webpack:client:dev": "webpack serve --config webpack.config.client.js --mode development",
    "webpack:server": "webpack --config webpack.config.server.js --mode production",
    "webpack:server:dev": "webpack -w --config webpack.config.server.js --mode development",
    "lint": "eslint",
    "test": "echo \"Error: no test specified\""
  },
